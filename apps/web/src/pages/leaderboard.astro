      .av-cta-code .comment { color: #475569; }
      .av-btn-primary {
        display: inline-block;
        padding: 0.625rem 1.5rem;
        background: linear-gradient(135deg, #06b6d4, #22d3ee);
        color: #0a1628;
        font-weight: 600;
        font-family: inherit;
        font-size: 0.85rem;
        border-radius: 4px;
