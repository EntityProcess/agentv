        "negate": { "type": "boolean" }
      },
      "required": ["type"],
      "anyOf": [
        { "required": ["max_total"] },
        { "required": ["max_input"] },
        { "required": ["max_output"] }
      ],
      "additionalProperties": false
    },
    "eval_execution_metrics": {
      "type": "object",
      "description": "Declarative threshold-based checks on execution metrics. At least one threshold is required (excluding exploration_tolerance).",
      "properties": {
        "type": { "const": "execution_metrics" },
