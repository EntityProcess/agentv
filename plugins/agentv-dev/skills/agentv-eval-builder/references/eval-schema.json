        "type": { "const": "token_usage" },
        "name": { "type": "string" },
        "max_total": {
          "type": "number",
          "minimum": 0,
          "description": "Maximum allowed total tokens (input + output + cached)"
        },
        "max_input": {
          "type": "number",
          "minimum": 0,
          "description": "Maximum allowed input tokens (prompt)"
        },
        "max_output": {
          "type": "number",
          "minimum": 0,
