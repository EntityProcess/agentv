{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentV Eval Schema",
  "description": "Schema for YAML evaluation files with conversation flows, multiple evaluators, and execution configuration",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Suite name identifier (lowercase alphanumeric with hyphens, 1-64 chars)",
      "pattern": "^[a-z0-9-]+$",
      "minLength": 1,
      "maxLength": 64
    },
    "description": {
      "type": "string",
      "description": "Description of what this eval suite covers",
      "maxLength": 1024
    },
    "version": {
      "type": "string",
      "description": "Suite version string"
    },
    "author": {
      "type": "string",
      "description": "Suite author"
    },
    "license": {
      "type": "string",
      "description": "Suite license identifier"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags for categorizing the suite"
    },
    "requires": {
      "type": "object",
      "description": "Engine version requirements",
      "properties": {
        "agentv": {
          "type": "string",
          "description": "Required agentv version (semver range)"
        }
      },
      "additionalProperties": false
    },
    "dataset": {
      "type": "string",
      "description": "Dataset name override (defaults to filename without extension)"
    },
    "target": {
      "type": "string",
      "description": "(Deprecated: use execution.target instead) Default target configuration name. Can be overridden per test."
    },
    "workspace": {
      "$ref": "#/$defs/workspace_config",
      "description": "Suite-level workspace configuration (applied to all tests, can be overridden per test)"
    },
    "assert": {
      "type": "array",
      "description": "Suite-level default assertions appended to every test's assertions (unless skip_defaults is set per test). Canonical replacement for execution.evaluators.",
      "items": { "$ref": "#/$defs/evaluator" }
    },
    "execution": {
      "type": "object",
      "description": "Default execution configuration for all tests (can be overridden per test)",
      "properties": {
        "target": {
          "type": "string",
          "description": "Default target configuration name (e.g., default, azure_base, vscode_projectx). Can be overridden per test."
        },
        "targets": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Target names for matrix evaluation (runs each test against all listed targets)"
        },
        "evaluators": {
          "type": "array",
          "description": "(Deprecated: use top-level 'assert' instead) Default evaluators appended to every test's evaluators",
          "items": { "$ref": "#/$defs/evaluator" }
        },
        "trials": {
          "type": "object",
          "description": "Configuration for running multiple trials per test case",
          "properties": {
            "count": {
              "type": "integer",
              "minimum": 1,
              "description": "Number of trial attempts per test"
            },
            "strategy": {
              "type": "string",
              "enum": ["pass_at_k", "mean", "confidence_interval"],
              "description": "Aggregation strategy for trial results (default: pass_at_k)"
            },
            "cost_limit_usd": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "Maximum cost in USD before stopping trials early"
            }
          },
          "required": ["count"],
          "additionalProperties": false
        },
        "cache": {
          "type": "boolean",
          "description": "Enable response caching for deterministic re-runs"
        },
        "cache_path": {
          "type": "string",
          "description": "Custom path for cache storage"
        },
        "total_budget_usd": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Maximum total cost budget in USD for the entire suite run"
        }
      },
      "additionalProperties": true
    },
    "input": {
      "description": "Suite-level input messages prepended to every test's input (unless test sets execution.skip_defaults: true). String expands to single user message, array of messages passes through.",
      "$ref": "#/$defs/input_value"
    },
    "tests": {
      "type": "array",
      "description": "Array of evaluation tests. Can also be a string path to an external file (YAML or JSONL).",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the test"
          },
          "conversation_id": {
            "type": "string",
            "description": "Optional conversation identifier for threading multiple tests together"
          },
          "criteria": {
            "type": "string",
            "description": "Description of what the AI should accomplish in this eval"
          },
          "note": {
            "type": "string",
            "description": "Optional note or additional context for the test. Use this to document test-specific considerations, known limitations, or rationale for expected behavior."
          },
          "input": {
            "description": "Input messages for the conversation. String expands to single user message, array of messages passes through.",
            "$ref": "#/$defs/input_value"
          },
          "expected_output": {
            "description": "Expected response messages. String expands to single assistant message, object wraps as assistant message content. The content of the last resolved entry becomes the template variable 'reference_answer'.",
            "oneOf": [
              {
                "type": "string",
                "description": "Shorthand: single assistant message content"
              },
              {
                "type": "object",
                "description": "Shorthand: structured content wraps as assistant message"
              },
              {
                "type": "array",
                "description": "Array of messages",
                "items": { "$ref": "#/$defs/message" }
              }
            ]
          },
          "assert": {
            "type": "array",
            "description": "Per-test assertions (canonical field). Suite-level assert items are appended unless skip_defaults is true.",
            "items": { "$ref": "#/$defs/evaluator" }
          },
          "rubrics": {
            "type": "array",
            "description": "(Deprecated: use assert with type: rubrics instead) Inline rubric items. Supports string shorthand or rubric item objects.",
            "items": {
              "oneOf": [
                {
                  "type": "string",
                  "description": "Shorthand: criterion text (auto-generates id, weight 1.0, required true)"
                },
                { "$ref": "#/$defs/rubric_item" }
              ]
            }
          },
          "workspace": {
            "$ref": "#/$defs/workspace_config",
            "description": "Per-test workspace configuration (overrides suite-level workspace)"
          },
          "metadata": {
            "type": "object",
            "description": "Arbitrary per-test metadata passed to workspace scripts via stdin",
            "additionalProperties": true
          },
          "execution": {
            "type": "object",
            "description": "Per-case execution configuration",
            "properties": {
              "target": {
                "type": "string",
                "description": "Override target for this specific test"
              },
              "targets": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Per-test target names for matrix evaluation (overrides suite-level targets)"
              },
              "skip_defaults": {
                "type": "boolean",
                "description": "When true, suite-level assert/evaluators and suite-level input are not appended to this test"
              },
              "evaluators": {
                "type": "array",
                "description": "(Deprecated: use top-level 'assert' on the test instead) Per-test evaluators",
                "items": { "$ref": "#/$defs/evaluator" }
              }
            },
            "additionalProperties": true
          }
        },
        "required": ["id", "criteria"],
        "anyOf": [{ "required": ["input"] }],
        "additionalProperties": true
      }
    }
  },
  "required": ["tests"],
  "additionalProperties": true,
  "$defs": {
    "input_value": {
      "oneOf": [
        {
          "type": "string",
          "description": "Shorthand: single user message content"
        },
        {
          "type": "array",
          "description": "Array of messages",
          "minItems": 1,
          "items": { "$ref": "#/$defs/message" }
        }
      ]
    },
    "message": {
      "type": "object",
      "properties": {
        "role": {
          "type": "string",
          "enum": ["system", "user", "assistant", "tool"],
          "description": "Message role"
        },
        "content": {
          "oneOf": [
            {
              "type": "string",
              "description": "Simple text content"
            },
            {
              "type": "object",
              "description": "Structured content object"
            },
            {
              "type": "array",
              "description": "Mixed content items (text and file references)",
              "items": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["text", "file"],
                    "description": "Content type: 'text' for inline content, 'file' for file references"
                  },
                  "value": {
                    "type": "string",
                    "description": "Text content or file path. Relative paths resolved from eval file directory, absolute paths resolved from repo root."
                  }
                },
                "required": ["type", "value"],
                "additionalProperties": false
              }
            }
          ]
        }
      },
      "required": ["role", "content"],
      "additionalProperties": false
    },
    "workspace_config": {
      "type": "object",
      "description": "Workspace configuration for eval tests. Lifecycle hooks follow bun:test/Vitest naming.",
      "properties": {
        "template": {
          "type": "string",
          "description": "Template directory or .code-workspace file. Directories are copied to temp workspace."
        },
        "before_all": {
          "$ref": "#/$defs/workspace_script",
          "description": "Command to run once before the first test (after workspace creation)"
        },
        "after_all": {
          "$ref": "#/$defs/workspace_script",
          "description": "Command to run once after the last test (before workspace cleanup)"
        },
        "before_each": {
          "$ref": "#/$defs/workspace_script",
          "description": "Command to run before each test"
        },
        "after_each": {
          "$ref": "#/$defs/workspace_script",
          "description": "Command to run after each test (e.g., git reset for workspace reuse)"
        }
      },
      "additionalProperties": false
    },
    "workspace_script": {
      "type": "object",
      "description": "Workspace lifecycle command configuration",
      "properties": {
        "command": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Command array to execute (e.g., [\"bun\", \"run\", \"setup.ts\"])"
        },
        "timeout_ms": {
          "type": "number",
          "description": "Optional timeout in milliseconds (default: 60000 for setup, 30000 for teardown)"
        },
        "cwd": {
          "type": "string",
          "description": "Optional working directory for command execution (relative paths resolved from eval file directory)"
        }
      },
      "required": ["command"],
      "additionalProperties": false
    },
    "rubric_item": {
      "type": "object",
      "description": "Rubric criterion for LLM judge evaluation. Supports checklist mode (boolean) and score-range mode (0-10 integer).",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for this criterion"
        },
        "outcome": {
          "type": "string",
          "description": "For checklist rubrics: the expected outcome text (required). For score-range rubrics: optional overall criterion description."
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "default": 1.0,
          "description": "Weight for aggregation (default: 1.0)"
        },
        "required": {
          "type": "boolean",
          "description": "(Deprecated: use required_min_score) Boolean gating — treated as required_min_score: 10"
        },
        "required_min_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10,
          "description": "Minimum score (0-10) required to pass this criterion"
        },
        "score_ranges": {
          "description": "Score range definitions for analytic rubric scoring. Ranges must be non-overlapping and cover 0-10 inclusive. Also accepts shorthand map format: { 0: 'Bad', 3: 'OK', 7: 'Good', 10: 'Perfect' }.",
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "score_range": {
                    "type": "array",
                    "items": { "type": "integer", "minimum": 0, "maximum": 10 },
                    "minItems": 2,
                    "maxItems": 2,
                    "description": "Inclusive integer range [min, max] within 0-10"
                  },
                  "outcome": {
                    "type": "string",
                    "description": "Description of what this score range represents"
                  }
                },
                "required": ["score_range", "outcome"],
                "additionalProperties": false
              }
            },
            {
              "type": "object",
              "description": "Shorthand map: keys are lower bounds (0-10), values are outcome descriptions"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "evaluator_common": {
      "description": "Common optional fields shared by all evaluator types",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Evaluator name/identifier. Auto-generated for assertion types (contains, regex, is_json, equals, rubrics) if not provided."
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "description": "Weight for top-level score aggregation (default: 1.0)"
        },
        "required": {
          "description": "When true, uses default 0.8 threshold. When a number (0-1], sets the minimum score threshold. If the evaluator scores below this, the overall verdict is 'fail'.",
          "oneOf": [
            { "type": "boolean" },
            { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
          ]
        },
        "negate": {
          "type": "boolean",
          "description": "When true, inverts the evaluator score (1 - score) and swaps pass/fail verdict"
        }
      }
    },
    "evaluator": {
      "description": "Evaluator/assertion configuration. The 'type' field determines which evaluator is used.",
      "type": "object",
      "oneOf": [
        { "$ref": "#/$defs/eval_code_judge" },
        { "$ref": "#/$defs/eval_llm_judge" },
        { "$ref": "#/$defs/eval_rubrics" },
        { "$ref": "#/$defs/eval_rubric_deprecated" },
        { "$ref": "#/$defs/eval_composite" },
        { "$ref": "#/$defs/eval_tool_trajectory" },
        { "$ref": "#/$defs/eval_field_accuracy" },
        { "$ref": "#/$defs/eval_latency" },
        { "$ref": "#/$defs/eval_cost" },
        { "$ref": "#/$defs/eval_token_usage" },
        { "$ref": "#/$defs/eval_execution_metrics" },
        { "$ref": "#/$defs/eval_agent_judge" },
        { "$ref": "#/$defs/eval_contains" },
        { "$ref": "#/$defs/eval_regex" },
        { "$ref": "#/$defs/eval_is_json" },
        { "$ref": "#/$defs/eval_equals" }
      ]
    },
    "eval_code_judge": {
      "type": "object",
      "description": "Runs a custom script to evaluate the candidate output",
      "properties": {
        "type": { "const": "code_judge" },
        "name": { "type": "string" },
        "command": {
          "description": "Command array or shell string to execute the judge script",
          "oneOf": [
            { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            { "type": "string" }
          ]
        },
        "cwd": {
          "type": "string",
          "description": "Working directory for command execution"
        },
        "target": {
          "description": "Enable target access via local proxy. Use true for defaults or an object for configuration.",
          "oneOf": [
            { "type": "boolean", "const": true },
            {
              "type": "object",
              "properties": {
                "max_calls": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Maximum number of target invocations (default: 50)"
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "config": {
          "type": "object",
          "description": "Pass-through configuration for the code_judge script (any extra YAML properties also get collected here)",
          "additionalProperties": true
        },
        "weight": { "type": "number", "minimum": 0 },
        "required": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
          ]
        },
        "negate": { "type": "boolean" }
      },
      "required": ["type", "command"],
      "additionalProperties": true
    },
    "eval_llm_judge": {
      "type": "object",
      "description": "Uses an LLM to evaluate the candidate output against a prompt and/or rubrics",
      "properties": {
        "type": { "const": "llm_judge" },
        "name": { "type": "string" },
        "prompt": {
          "description": "Evaluation prompt — file path (resolved relative to eval file), inline text, or executable script config",
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "description": "Executable prompt template",
              "properties": {
                "command": {
                  "type": "array",
                  "items": { "type": "string" },
                  "minItems": 1,
                  "description": "Command array to execute (e.g., [\"bun\", \"run\", \"template.ts\"])"
                },
                "config": {
                  "type": "object",
                  "description": "Pass-through configuration for the prompt template",
                  "additionalProperties": true
                }
              },
              "required": ["command"],
              "additionalProperties": false
            }
          ]
        },
        "rubrics": {
          "type": "array",
          "description": "Structured rubric items for evaluation",
          "items": { "$ref": "#/$defs/rubric_item" }
        },
        "config": {
          "type": "object",
          "description": "Pass-through configuration for custom evaluator prompts",
          "additionalProperties": true
        },
        "weight": { "type": "number", "minimum": 0 },
        "required": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
          ]
        },
        "negate": { "type": "boolean" }
      },
      "required": ["type"],
      "additionalProperties": true
    },
    "eval_rubrics": {
      "type": "object",
      "description": "Evaluates candidate output against a list of rubric criteria (syntactic sugar for llm_judge with rubrics)",
      "properties": {
        "type": { "const": "rubrics" },
        "name": { "type": "string" },
        "criteria": {
          "type": "array",
          "description": "Rubric criteria. Supports string shorthand or rubric item objects.",
          "minItems": 1,
          "items": {
            "oneOf": [
              {
                "type": "string",
                "description": "Shorthand: criterion text (auto-generates id, weight 1.0, required true)"
              },
              { "$ref": "#/$defs/rubric_item" }
            ]
          }
        },
        "weight": { "type": "number", "minimum": 0 },
        "required": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
          ]
        },
        "negate": { "type": "boolean" }
      },
      "required": ["type", "criteria"],
      "additionalProperties": false
    },
    "eval_rubric_deprecated": {
      "type": "object",
      "description": "(Deprecated: use type: rubrics with criteria instead) Evaluates using rubric items",
      "properties": {
        "type": { "const": "rubric" },
        "name": { "type": "string" },
        "rubrics": {
          "type": "array",
          "description": "Rubric items for evaluation",
          "minItems": 1,
          "items": { "$ref": "#/$defs/rubric_item" }
        },
        "weight": { "type": "number", "minimum": 0 },
        "required": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
          ]
        },
        "negate": { "type": "boolean" }
      },
      "required": ["type", "rubrics"],
      "additionalProperties": false
    },
    "eval_composite": {
      "type": "object",
      "description": "Combines multiple child evaluators with an aggregation strategy",
      "properties": {
        "type": { "const": "composite" },
        "name": { "type": "string" },
        "assert": {
          "type": "array",
          "description": "Child evaluators (canonical field)",
          "items": { "$ref": "#/$defs/evaluator" }
        },
        "evaluators": {
          "type": "array",
          "description": "(Deprecated: use 'assert' instead) Child evaluators",
          "items": { "$ref": "#/$defs/evaluator" }
        },
        "aggregator": {
          "type": "object",
          "description": "Strategy for combining child evaluator scores",
          "oneOf": [
            {
              "properties": {
                "type": { "const": "weighted_average" },
                "weights": {
                  "type": "object",
                  "description": "Weight overrides by evaluator name",
                  "additionalProperties": { "type": "number" }
                }
              },
              "required": ["type"],
              "additionalProperties": false
            },
            {
              "properties": {
                "type": { "const": "code_judge" },
                "path": { "type": "string", "description": "Path to aggregator script" },
                "cwd": { "type": "string" }
              },
              "required": ["type", "path"],
              "additionalProperties": false
            },
            {
              "properties": {
                "type": { "const": "llm_judge" },
                "prompt": { "type": "string", "description": "Path to aggregator prompt file" },
                "model": { "type": "string" }
              },
              "required": ["type"],
              "additionalProperties": false
            },
            {
              "properties": {
                "type": { "const": "threshold" },
                "threshold": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Minimum score threshold (0.0-1.0)"
                }
              },
              "required": ["type", "threshold"],
              "additionalProperties": false
            }
          ]
        },
        "weight": { "type": "number", "minimum": 0 },
        "required": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
          ]
        },
        "negate": { "type": "boolean" }
      },
      "required": ["type", "aggregator"],
      "additionalProperties": false
    },
    "eval_tool_trajectory": {
      "type": "object",
      "description": "Validates the sequence and/or counts of tool calls made during execution",
      "properties": {
        "type": { "const": "tool_trajectory" },
        "name": { "type": "string" },
        "mode": {
          "type": "string",
          "enum": ["any_order", "in_order", "exact", "subset", "superset"],
          "description": "Matching mode: any_order (requires minimums), in_order/exact/subset/superset (require expected)"
        },
        "minimums": {
          "type": "object",
          "description": "Minimum call counts per tool name (for any_order mode)",
          "additionalProperties": { "type": "number", "minimum": 0 }
        },
        "expected": {
          "type": "array",
          "description": "Expected tool call sequence (for in_order/exact/subset/superset modes)",
          "items": {
            "type": "object",
            "properties": {
              "tool": { "type": "string", "description": "Expected tool name" },
              "args": {
                "description": "Argument matching: 'any' skips validation, object performs partial deep equality",
                "oneOf": [{ "const": "any" }, { "type": "object" }]
              },
              "max_duration_ms": {
                "type": "number",
                "minimum": 0,
                "description": "Maximum duration in milliseconds for this tool call"
              },
              "args_match": {
                "description": "Per-item argument matching mode override",
                "oneOf": [
                  { "type": "string", "enum": ["exact", "superset", "subset", "ignore"] },
                  {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Field list: specific field paths to compare"
                  }
                ]
              }
            },
            "required": ["tool"],
            "additionalProperties": false
          }
        },
        "args_match": {
          "description": "Default argument matching mode for all expected items",
          "oneOf": [
            { "type": "string", "enum": ["exact", "superset", "subset", "ignore"] },
            {
              "type": "array",
              "items": { "type": "string" },
              "description": "Field list: specific field paths to compare"
            }
          ]
        },
        "weight": { "type": "number", "minimum": 0 },
        "required": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
          ]
        },
        "negate": { "type": "boolean" }
      },
      "required": ["type", "mode"],
      "additionalProperties": false
    },
    "eval_field_accuracy": {
      "type": "object",
      "description": "Compares specific fields between candidate and expected output",
      "properties": {
        "type": { "const": "field_accuracy" },
        "name": { "type": "string" },
        "fields": {
          "type": "array",
          "description": "Fields to compare between candidate and expected",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "description": "Dot-notation path to the field (e.g., 'invoice.vendor.name' or 'items[0].amount')"
              },
              "match": {
                "type": "string",
                "enum": ["exact", "numeric_tolerance", "date"],
                "description": "Match strategy. For fuzzy string matching, use a code_judge evaluator."
              },
              "required": {
                "type": "boolean",
                "description": "Whether this field is required (missing required fields count as failures)"
              },
              "weight": {
                "type": "number",
                "minimum": 0,
                "description": "Weight for aggregation (default: 1.0)"
              },
              "tolerance": {
                "type": "number",
                "description": "Tolerance for numeric matching (absolute unless relative is true)"
              },
              "relative": {
                "type": "boolean",
                "description": "Whether tolerance is relative (percentage) vs absolute"
              },
              "formats": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Date formats to try when parsing (default: common formats)"
              }
            },
            "required": ["path", "match"],
            "additionalProperties": false
          }
        },
        "aggregation": {
          "type": "string",
          "enum": ["weighted_average", "all_or_nothing"],
          "description": "Strategy for combining field scores (default: weighted_average)"
        },
        "weight": { "type": "number", "minimum": 0 },
        "required": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
          ]
        },
        "negate": { "type": "boolean" }
      },
      "required": ["type", "fields"],
      "additionalProperties": false
    },
    "eval_latency": {
