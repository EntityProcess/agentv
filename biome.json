{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "files": {
    "ignore": [
      "node_modules",
      "dist",
      "build",
      "out",
      ".next",
      "coverage",
      ".turbo",
      ".cache",
      "**/generated/**",
      "**/*.gen.ts",
      "**/__generated__/**",
      "**/test-output/**",
      "**/__tmp_*/**",
      "**/.agentv/**",
      ".claude/**",
      ".ntm/**",
      ".opencode/**",
      ".beads/**",
      ".entire/**",
      ".mcp.json",
      "codex.mcp.json",
      "cline.mcp.json",
      "factory.mcp.json",
      "windsurf.mcp.json",
      ".worktrees/**",
      "**/.astro/**",
      "**/*.tsbuildinfo",
      "logs",
      "*.log"
    ]
  }
}
